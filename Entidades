CREATE TABLE Cliente (
    ClienteId INT PRIMARY KEY IDENTITY,
    Nombre NVARCHAR(100),
    Telefono NVARCHAR(20),
    Direccion NVARCHAR(200),
    Email NVARCHAR(100)
);

CREATE TABLE Mascota (
    MascotaId INT PRIMARY KEY IDENTITY,
    Nombre NVARCHAR(100),
    Especie NVARCHAR(50),
    Raza NVARCHAR(50),
    Edad INT,
    ClienteId INT,
    FOREIGN KEY (ClienteId) REFERENCES Cliente(ClienteId)
);

CREATE TABLE Veterinario (
    VeterinarioId INT PRIMARY KEY IDENTITY,
    Nombre NVARCHAR(100),
    Especialidad NVARCHAR(100),
    Telefono NVARCHAR(20)
);

CREATE TABLE Cita (
    CitaId INT PRIMARY KEY IDENTITY,
    Fecha DATETIME,
    MascotaId INT,
    VeterinarioId INT,
    Estado NVARCHAR(50),
    FOREIGN KEY (MascotaId) REFERENCES Mascota(MascotaId),
    FOREIGN KEY (VeterinarioId) REFERENCES Veterinario(VeterinarioId)
);

CREATE TABLE Consulta (
    ConsultaId INT PRIMARY KEY IDENTITY,
    CitaId INT UNIQUE,
    Diagnostico NVARCHAR(200),
    Observaciones NVARCHAR(300),
    FOREIGN KEY (CitaId) REFERENCES Cita(CitaId)
);

CREATE TABLE HistorialMedico (
    HistorialId INT PRIMARY KEY IDENTITY,
    MascotaId INT,
    Fecha DATETIME,
    Descripcion NVARCHAR(300),
    FOREIGN KEY (MascotaId) REFERENCES Mascota(MascotaId)
);

CREATE TABLE Tratamiento (
    TratamientoId INT PRIMARY KEY IDENTITY,
    ConsultaId INT,
    Medicamento NVARCHAR(100),
    Dosis NVARCHAR(50),
    Indicaciones NVARCHAR(200),
    FOREIGN KEY (ConsultaId) REFERENCES Consulta(ConsultaId)
);
